CARTESIA_VOICE_FR=  # French — e.g. Roxane: 328e0683-d1a7-4cde-ad46-0ee69a3cbd6a
CARTESIA_VOICE_DE=  # German — e.g. Alina: 38aabb6a-f52b-4fb0-a3d1-988518f4dc06
