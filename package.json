{
  "name": "linguist",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "description": "Linguist language learning platform",
  "scripts": {
    "dev:desktop": "pnpm --filter @linguist/desktop dev",
    "dev:web": "pnpm --filter @linguist/web dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "build:dict": "tsx packages/core/src/ime/build-dictionary-index.ts"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.2",
    "prisma": "^6.3.0",
    "tsx": "^4.7.0",
    "turbo": "^2.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0"
  }
}
