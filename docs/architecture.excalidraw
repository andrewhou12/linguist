      "link": null,
      "locked": false,
      "text": "createInitialFsrsState() -> FsrsState\nscheduleReview(state, grade) -> { nextState, interval }\ncomputeReviewQueue(items) -> sorted due items[]\n\nUses: ts-fsrs library | Target retention: 0.90\nGrade map: again->1 hard->2 good->3 easy->4",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "createInitialFsrsState() -> FsrsState\nscheduleReview(state, grade) -> { nextState, interval }\ncomputeReviewQueue(items) -> sorted due items[]\n\nUses: ts-fsrs library | Target retention: 0.90\nGrade map: again->1 hard->2 good->3 easy->4",
      "autoResize": true,
      "lineHeight": 1.35
    },
