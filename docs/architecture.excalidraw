      ],
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772154028652,
      "link": null,
      "locked": false,
      "text": "detectAvoidance(items, sessions)\n  -> journeyman 3+ sessions, 0 conversation production\ndetectConfusionPairs(errors)\n  -> item pairs co-occurring in errors >=2x\ndetectRegression(items, reviews)\n  -> expert/master with again/hard in last 3 reviews\ndetectModalityGap(items)\n  -> retrievability gap between modalities\ngenerateExpandedDailyBrief() -> ExpandedTomBrief",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "detectAvoidance(items, sessions)\n  -> journeyman 3+ sessions, 0 conversation production\ndetectConfusionPairs(errors)\n  -> item pairs co-occurring in errors >=2x\ndetectRegression(items, reviews)\n  -> expert/master with again/hard in last 3 reviews\ndetectModalityGap(items)\n  -> retrievability gap between modalities\ngenerateExpandedDailyBrief() -> ExpandedTomBrief",
      "autoResize": true,
      "lineHeight": 1.35
    },
