    {
      "id": "elem_190_634595a9",
      "type": "text",
      "x": 72,
      "y": 3139,
      "width": 362.38,
      "height": 197.05,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
