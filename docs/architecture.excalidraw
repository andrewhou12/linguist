    {
      "id": "elem_46_ebce8723",
      "type": "text",
      "x": 1032,
      "y": 1224,
      "width": 724.3,
      "height": 214.60000000000002,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "elem_42_9ef5df92"
      ],
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772154028650,
      "link": null,
      "locked": false,
      "text": "/api/review/       queue, submit, summary       /api/tom/          analyze, brief, inferences\n/api/wordbank/     GET/POST, [id], search       /api/curriculum/   bubble, recommendations, ...\n/api/wordbank/[id]/promote  POST               /api/grammar/[id]/promote  POST\n/api/conversation/ plan, send(SSE), end, list   /api/narrative/    draft, polish\n/api/conversation/[id]  GET (full session)      /api/profile/      GET/PUT, recalculate\n/api/grammar/      GET (list + search)          /api/context-log/  POST\n/api/chunks/       GET (list + search)          /api/onboarding/   status, assessment, complete\n/api/chat/         POST (streaming)             /api/dashboard/    frontier, weekly-stats\n/api/pragmatic/    GET/PUT                      /api/user/         me\n\nEvery route: getSupabaseUser() -> @linguist/core functions -> @linguist/db Prisma writes\nconversation/send: SSE streaming via anthropic.messages.stream() -> ReadableStream",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "/api/review/       queue, submit, summary       /api/tom/          analyze, brief, inferences\n/api/wordbank/     GET/POST, [id], search       /api/curriculum/   bubble, recommendations, ...\n/api/wordbank/[id]/promote  POST               /api/grammar/[id]/promote  POST\n/api/conversation/ plan, send(SSE), end, list   /api/narrative/    draft, polish\n/api/conversation/[id]  GET (full session)      /api/profile/      GET/PUT, recalculate\n/api/grammar/      GET (list + search)          /api/context-log/  POST\n/api/chunks/       GET (list + search)          /api/onboarding/   status, assessment, complete\n/api/chat/         POST (streaming)             /api/dashboard/    frontier, weekly-stats\n/api/pragmatic/    GET/PUT                      /api/user/         me\n\nEvery route: getSupabaseUser() -> @linguist/core functions -> @linguist/db Prisma writes\nconversation/send: SSE streaming via anthropic.messages.stream() -> ReadableStream",
      "autoResize": true,
      "lineHeight": 1.35
    },
