      "text": "Flow B: Full Conversation Session (4 Claude API Calls)",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Flow B: Full Conversation Session (4 Claude API Calls)",
      "autoResize": true,
