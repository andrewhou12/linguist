    {
      "id": "tool-zone-content",
      "type": "text",
      "x": 80,
      "y": 1680,
      "width": 700,
      "height": 130,
      "text": "suggestActions      → chips    → Bottom suggestion chips (extracted from last assistant message)\ndisplayChoices      → inline   → Always rendered inline in chat as numbered buttons\nshowCorrection      → panel    → Card in side panel + small reference pill inline\nshowVocabularyCard  → panel    → Card in side panel + small reference pill inline  (📘 食べる)\nshowGrammarNote     → panel    → Card in side panel + small reference pill inline  (📕 ～てもいいですか)\nupdateSessionPlan   → hidden   → Silently updates plan in DB + client state\n\nWhen panel is CLOSED: panel-zone tools render full cards inline (V1 behavior preserved)",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "groupIds": [],
      "isDeleted": false,
      "boundElements": [],
      "link": null,
      "locked": false,
      "containerId": null,
      "originalText": "suggestActions      → chips    → Bottom suggestion chips (extracted from last assistant message)\ndisplayChoices      → inline   → Always rendered inline in chat as numbered buttons\nshowCorrection      → panel    → Card in side panel + small reference pill inline\nshowVocabularyCard  → panel    → Card in side panel + small reference pill inline  (📘 食べる)\nshowGrammarNote     → panel    → Card in side panel + small reference pill inline  (📕 ～てもいいですか)\nupdateSessionPlan   → hidden   → Silently updates plan in DB + client state\n\nWhen panel is CLOSED: panel-zone tools render full cards inline (V1 behavior preserved)",
      "autoResize": true,
      "lineHeight": 1.35,
      "version": 3,
      "versionNonce": 1634403139,
      "index": "g1",
      "strokeStyle": "solid",
      "seed": 1,
      "frameId": null,
      "roundness": null,
      "updated": 1772654978303
    },

