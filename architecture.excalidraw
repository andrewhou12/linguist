    {
      "id": "elem_182_2977c60c",
      "type": "text",
      "x": 72,
      "y": 3036,
      "width": 460.4,
      "height": 284.8,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "elem_178_4b651a0e"
      ],
      "isDeleted": false,
      "boundElements": null,
      "updated": 1771901657422,
      "link": null,
      "locked": false,
      "text": " 1. User grades card (e.g. 'Good')\n 2. → useReview.submitReview(submission)\n 3. → window.linguist.reviewSubmit(submission)\n 4. → IPC invoke → electron/ipc/reviews.ts handler\n 5. → core/fsrs:    scheduleReview(currentFsrs, 'good')\n 6. → core/mastery:  computeNextMasteryState(context)\n 7. → Prisma:  UPDATE LexicalItem SET fsrs, masteryState\n 8. → Prisma:  CREATE ReviewEvent row\n 9. → Prisma:  CREATE ItemContextLog row\n10. → (every 10th review) core/profile: recalculateProfile()\n11. → Return { newMasteryState, newFsrsState } to renderer\n\nTotal latency: ~5-15ms (all local, no network)\n\nKey detail: Recognition and production FSRS states\nare tracked SEPARATELY per item.",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": " 1. User grades card (e.g. 'Good')\n 2. → useReview.submitReview(submission)\n 3. → window.linguist.reviewSubmit(submission)\n 4. → IPC invoke → electron/ipc/reviews.ts handler\n 5. → core/fsrs:    scheduleReview(currentFsrs, 'good')\n 6. → core/mastery:  computeNextMasteryState(context)\n 7. → Prisma:  UPDATE LexicalItem SET fsrs, masteryState\n 8. → Prisma:  CREATE ReviewEvent row\n 9. → Prisma:  CREATE ItemContextLog row\n10. → (every 10th review) core/profile: recalculateProfile()\n11. → Return { newMasteryState, newFsrsState } to renderer\n\nTotal latency: ~5-15ms (all local, no network)\n\nKey detail: Recognition and production FSRS states\nare tracked SEPARATELY per item.",
      "autoResize": true,
      "lineHeight": 1.35
    },
