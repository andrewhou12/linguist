    {
      "id": "elem_309_e40890f4",
      "type": "text",
      "x": 72,
      "y": 5671,
      "width": 543.3399999999999,
      "height": 249.70000000000002,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
